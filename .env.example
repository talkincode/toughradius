# ToughRADIUS 环境变量配置文件
# 复制此文件为 .env 并根据需要修改配置

# ============================================
# 系统配置
# ============================================
TOUGHRADIUS_SYSTEM_WORKER_DIR=/var/toughradius
TOUGHRADIUS_SYSTEM_DEBUG=true

# ============================================
# Web 服务配置
# ============================================
TOUGHRADIUS_WEB_HOST=0.0.0.0
TOUGHRADIUS_WEB_PORT=1816
# 设为 false 可关闭内置 HTTPS 管理监听
TOUGHRADIUS_WEB_TLS_ENABLED=true
TOUGHRADIUS_WEB_TLS_PORT=1817
# 必须在生产环境改为每个实例唯一的长随机值；该值用于签发管理后台 JWT。
TOUGHRADIUS_WEB_SECRET=change-me-to-a-long-random-string

# ============================================
# 数据库配置
# ============================================
# 数据库类型: sqlite 或 postgres
TOUGHRADIUS_DB_TYPE=sqlite

# SQLite 配置（当 TOUGHRADIUS_DB_TYPE=sqlite 时使用）
TOUGHRADIUS_DB_NAME=toughradius.db

# PostgreSQL 配置（当 TOUGHRADIUS_DB_TYPE=postgres 时使用）
# TOUGHRADIUS_DB_TYPE=postgres
# TOUGHRADIUS_DB_HOST=127.0.0.1
# TOUGHRADIUS_DB_PORT=5432
# TOUGHRADIUS_DB_NAME=toughradius
# TOUGHRADIUS_DB_USER=postgres
# TOUGHRADIUS_DB_PWD=mypassword

TOUGHRADIUS_DB_DEBUG=false

# ============================================
# RADIUS 服务配置
# ============================================
TOUGHRADIUS_RADIUS_ENABLED=true
TOUGHRADIUS_RADIUS_HOST=0.0.0.0
TOUGHRADIUS_RADIUS_AUTHPORT=1812
TOUGHRADIUS_RADIUS_ACCTPORT=1813
TOUGHRADIUS_RADIUS_RADSEC_PORT=2083
TOUGHRADIUS_RADIUS_RADSEC_WORKER=100
TOUGHRADIUS_RADIUS_DEBUG=true

# ============================================
# 日志配置
# ============================================
TOUGHRADIUS_LOGGER_MODE=development
TOUGHRADIUS_LOGGER_FILE_ENABLE=true
