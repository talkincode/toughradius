{
  "schemas": [
    {
      "key": "radius.EapMethod",
      "type": "string",
      "default": "eap-md5",
      "enum": ["eap-md5", "eap-mschapv2", "eap-tls", "eap-peap"],
      "title": "EAP Method",
      "title_i18n": "config.radius.eap_method.title",
      "description": "EAP authentication method. eap-peap reuses the EAP-TLS server certificate/key (EapTlsCertFile/EapTlsKeyFile) to build the outer TLS tunnel and runs EAP-MSCHAPv2 inside it for Windows/AD compatibility; the inner MS-CHAPv2 carries an NTLMv1-like attack surface (per Microsoft), so keep the outer TLS strong and prefer eap-tls where clients support certificates.",
      "description_i18n": "config.radius.eap_method.description"
    },
    {
      "key": "radius.EapEnabledHandlers",
      "type": "string",
      "default": "*",
      "title": "Enabled EAP Handlers",
      "title_i18n": "config.radius.eap_enabled_handlers.title",
      "description": "Comma-separated list of enabled EAP handler names (e.g., eap-md5,eap-mschapv2). Use * to allow all registered handlers",
      "description_i18n": "config.radius.eap_enabled_handlers.description"
    },
    {
      "key": "radius.EapTlsCertFile",
      "type": "string",
      "default": "",
      "title": "EAP-TLS Server Certificate",
      "title_i18n": "config.radius.eap_tls_cert_file.title",
      "description": "Path to the PEM server certificate the RADIUS server presents during the EAP-TLS handshake (RFC 5216 §2.2). Leave empty to keep EAP-TLS disabled",
      "description_i18n": "config.radius.eap_tls_cert_file.description"
    },
    {
      "key": "radius.EapTlsKeyFile",
      "type": "string",
      "default": "",
      "title": "EAP-TLS Server Private Key",
      "title_i18n": "config.radius.eap_tls_key_file.title",
      "description": "Path to the PEM private key matching the EAP-TLS server certificate. Leave empty to keep EAP-TLS disabled",
      "description_i18n": "config.radius.eap_tls_key_file.description"
    },
    {
      "key": "radius.EapTlsCaFile",
      "type": "string",
      "default": "",
      "title": "EAP-TLS Client CA Bundle",
      "title_i18n": "config.radius.eap_tls_ca_file.title",
      "description": "Path to the PEM CA bundle used to verify EAP-TLS client certificate chains (RFC 5216 §2.2/§5.3). Leave empty to keep EAP-TLS disabled",
      "description_i18n": "config.radius.eap_tls_ca_file.description"
    },
    {
      "key": "radius.EapTlsMinVersion",
      "type": "string",
      "default": "1.2",
      "enum": ["1.2", "1.3"],
      "title": "EAP-TLS Minimum TLS Version",
      "title_i18n": "config.radius.eap_tls_min_version.title",
      "description": "Minimum TLS protocol version accepted for EAP-TLS handshakes",
      "description_i18n": "config.radius.eap_tls_min_version.description"
    },
    {
      "key": "radius.IgnorePassword",
      "type": "bool",
      "default": "false",
      "title": "Ignore Password",
      "title_i18n": "config.radius.ignore_password.title",
      "description": "Ignore password check",
      "description_i18n": "config.radius.ignore_password.description"
    },
    {
      "key": "radius.AccountingHistoryDays",
      "type": "int",
      "default": "90",
      "min": 0,
      "title": "Accounting History Days",
      "title_i18n": "config.radius.accounting_history_days.title",
      "description": "Accounting log retention days (0=disabled)",
      "description_i18n": "config.radius.accounting_history_days.description"
    },
    {
      "key": "radius.AcctInterimInterval",
      "type": "int",
      "default": "300",
      "min": 60,
      "max": 3600,
      "title": "Accounting Interim Interval",
      "title_i18n": "config.radius.acct_interim_interval.title",
      "description": "Accounting interim interval in seconds",
      "description_i18n": "config.radius.acct_interim_interval.description"
    },
    {
      "key": "radius.SessionTimeout",
      "type": "int",
      "default": "3600",
      "min": 300,
      "max": 86400,
      "title": "Session Timeout",
      "title_i18n": "config.radius.session_timeout.title",
      "description": "Default session timeout in seconds",
      "description_i18n": "config.radius.session_timeout.description"
    },
    {
      "key": "radius.LogLevel",
      "type": "string",
      "default": "info",
      "enum": ["debug", "info", "warn", "error"],
      "title": "Log Level",
      "title_i18n": "config.radius.log_level.title",
      "description": "RADIUS service log level",
      "description_i18n": "config.radius.log_level.description"
    },
    {
      "key": "radius.RejectDelayMaxRejects",
      "type": "int",
      "default": "7",
      "min": 1,
      "max": 1000,
      "title": "Reject Delay Threshold",
      "title_i18n": "config.radius.reject_delay_max_rejects.title",
      "description": "Maximum consecutive rejects before temporary block",
      "description_i18n": "config.radius.reject_delay_max_rejects.description"
    },
    {
      "key": "radius.RejectDelayWindowSeconds",
      "type": "int",
      "default": "10",
      "min": 1,
      "max": 3600,
      "title": "Reject Delay Window",
      "title_i18n": "config.radius.reject_delay_window_seconds.title",
      "description": "Observation window (seconds) for reject counter reset",
      "description_i18n": "config.radius.reject_delay_window_seconds.description"
    }
  ]
}